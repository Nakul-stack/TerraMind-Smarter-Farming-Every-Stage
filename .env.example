# ─── TerraMind Chatbot Environment Variables ───────────────────────────
# Copy this file to .env and customise as needed.
# All values below show the defaults — you only need to set variables
# whose defaults you want to override.

# Path to the folder containing PDF documents
# TERRAMIND_PDF_FOLDER=../../chatbot

# Path to store the FAISS index and chunk metadata
# TERRAMIND_VECTOR_STORE_DIR=backend/app/chatbot/storage

# Sentence-transformer model for embeddings
# TERRAMIND_EMBEDDING_MODEL=all-MiniLM-L6-v2

# OpenRouter settings (recommended)
# OPENROUTER_API_KEY=your_server_side_key_here
# OPENROUTER_MODEL_NAME=z-ai/glm-4.5-air:free
# OPENROUTER_REASONING_EFFORT=low
# GRAPH_RAG_LLM_MAX_TOKENS=1200
# GRAPH_RAG_LLM_RETRY_MAX_TOKENS=1600
# Optional: fallback model used by GraphRAG when primary model is rate-limited
# GRAPH_RAG_FALLBACK_MODEL=z-ai/glm-4.5-air:free
# Optional: ordered fallback list (comma-separated)
# GRAPH_RAG_MODEL_CANDIDATES=z-ai/glm-4.5-air:free
# OPENROUTER_TEMPERATURE=0.3
# OPENROUTER_TIMEOUT=120

# Legacy Ollama variables (optional compatibility)
# OLLAMA_MODEL_NAME=z-ai/glm-4.5-air:free
# OLLAMA_TEMPERATURE=0.3
# OLLAMA_TIMEOUT=120

# Chunking
# TERRAMIND_CHUNK_SIZE=500
# TERRAMIND_CHUNK_OVERLAP=50

# Retrieval
# TERRAMIND_TOP_K=5
# TERRAMIND_MAX_CONTEXT_CHUNKS=5
# TERRAMIND_SIM_THRESHOLD=0.35

# API operational limits
# TERRAMIND_API_RATE_LIMIT=10/minute
# TERRAMIND_ADVISOR_PREDICT_RATE_LIMIT=15/minute
# TERRAMIND_ADVISOR_TRAIN_RATE_LIMIT=2/minute
# TERRAMIND_MONITOR_PREDICT_RATE_LIMIT=15/minute
# TERRAMIND_CHATBOT_ASK_RATE_LIMIT=10/minute
# TERRAMIND_CHATBOT_REBUILD_RATE_LIMIT=5/minute
# TERRAMIND_DIAGNOSIS_RATE_LIMIT=10/minute
# TERRAMIND_DIAGNOSIS_TOP_K_DEFAULT=3
# TERRAMIND_DIAGNOSIS_TOP_K_MIN=1
# TERRAMIND_DIAGNOSIS_TOP_K_MAX=20
# TERRAMIND_DIAGNOSIS_REPORT_TTL_SECONDS=1800
# TERRAMIND_DIAGNOSIS_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/jpg
# TERRAMIND_REPORT_NUM_PREDICT=1500
